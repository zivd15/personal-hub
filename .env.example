NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── WhatsApp chatbot (Cloudflare Pages Function) ──────────────────────────────
# Required — set these in Cloudflare Pages → Settings → Environment variables
WHATSAPP_VERIFY_TOKEN=your-custom-verify-token
WHATSAPP_ACCESS_TOKEN=your-meta-app-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Optional
ALLOWED_PHONE=972501234567   # restrict bot to a single WhatsApp number
SHOP_LIST_ID=                # UUID of an existing grocery list to use
